/ {
    pwmleds {
        compatible = "pwm-leds";
        disp_bl: pwm_led_1 {
            pwms = <&pwm1 0 PWM_MSEC(1) PWM_POLARITY_NORMAL>;
        };
    };
};

&pinctrl {
    pwm1_default: pwm1_default {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 15)>; /* pro_micro 3 / D3 */
            nordic,invert;
        };
    };

    pwm1_sleep: pwm1_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 15)>; /* pro_micro 3 / D3 */
            low-power-enable;
        };
    };
};

&pwm1 {
    status = "okay";
    pinctrl-0 = <&pwm1_default>;
    pinctrl-1 = <&pwm1_sleep>;
    pinctrl-names = "default", "sleep";
};

&pro_micro_spi {
    status = "okay";
    cs-gpios = <&pro_micro 1 GPIO_ACTIVE_LOW>; /* pro_micro 1 / D1 */
};

/ {
    mipi_dbi {
        compatible = "zephyr,mipi-dbi-spi";
        spi-dev = <&pro_micro_spi>;
        dc-gpios = <&pro_micro 0 GPIO_ACTIVE_HIGH>; /* pro_micro 0 / D0 */
        reset-gpios = <&pro_micro 2 GPIO_ACTIVE_LOW>; /* pro_micro 2 / D2 */
        write-only;
        #address-cells = <1>;
        #size-cells = <0>;

        st7789: st7789v@0 {
            compatible = "sitronix,st7789v";
            mipi-max-frequency = <30000000>;
            mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";
            reg = <0>;
            width = <240>;
            height = <280>;
            x-offset = <0>;
            y-offset = <20>;
            vcom = <0x19>;
            gctrl = <0x35>;
            vrhs = <0x12>;
            vdvs = <0x20>;
            mdac = <0x00>;
            gamma = <0x01>;
            colmod = <0x05>;
            lcm = <0x2c>;
            porch-param = [ 0c 0c 00 33 33  ];
            cmd2en-param = [ 5a 69 02 01  ];
            pwctrl1-param = [ a4 a1  ];
            pvgam-param = [ D0 04 0D 11 13 2B 3F 54 4C 18 0D 0B 1F 23  ];
            nvgam-param = [ D0 04 0C 11 13 2C 3F 44 51 2F 1F 1F 20 23  ];
            ram-param = [ 00 F0  ];
            rgb-param = [ CD 08 14  ];
        };
    };
};
